{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "__APP_VERSION__",
  "default_locale": "en",
  "description": "__MSG_extDescription__",
  "browser_specific_settings": {
    "gecko": {
      "id": "zimbra_mail_notifier@davidguehennec.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "authenticationInfo"
        ],
        "optional": []
      }
    }
  },
  "action": {
    "default_icon": {
      "16": "skin/images/zimbra_mail_notifier_16.png",
      "32": "skin/images/zimbra_mail_notifier_32.png",
      "48": "skin/images/zimbra_mail_notifier_48.png",
      "64": "skin/images/zimbra_mail_notifier_64.png",
      "128": "skin/images/zimbra_mail_notifier_128.png"
    },
    "default_popup": "popup.html",
    "default_title": "__MSG_extName__"
  },
  "icons": {
    "16": "skin/images/zimbra_mail_notifier_16.png",
    "32": "skin/images/zimbra_mail_notifier_32.png",
    "48": "skin/images/zimbra_mail_notifier_48.png",
    "64": "skin/images/zimbra_mail_notifier_64.png",
    "128": "skin/images/zimbra_mail_notifier_128.png"
  },
  "permissions": [
    "notifications",
    "cookies",
    "storage",
    "alarms"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "scripts": ["js/worker.js"],
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
